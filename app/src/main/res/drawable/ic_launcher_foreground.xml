<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer accent rings for a modern tech logo aesthetic -->
    <path
        android:fillColor="#00000000"
        android:strokeWidth="1.5"
        android:strokeColor="#1F2DD4BF"
        android:pathData="M 54,18 A 36,36 0 1,1 53.9,18 Z" />
    <path
        android:fillColor="#00000000"
        android:strokeWidth="1"
        android:strokeColor="#0F2DD4BF"
        android:pathData="M 54,12 A 42,42 0 1,1 53.9,12 Z" />

    <!-- Center core branding symbol (Modern Abstract Tech Peak / Compose Triangle Play Button) -->
    <!-- Centered strictly inside a 66dp safe zone (i.e., within 21 to 87 range) -->
    <path
        android:pathData="M 42,32 L 80,54 L 42,76 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="42"
                android:startY="32"
                android:endX="80"
                android:endY="76"
                android:type="linear">
                <item android:offset="0" android:color="#2DD4BF" />
                <item android:offset="1" android:color="#00F2FE" />
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Secondary overlapping element for geometric depth -->
    <path
        android:pathData="M 42,32 L 61,54 L 42,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="42"
                android:startY="32"
                android:endX="61"
                android:endY="54"
                android:type="linear">
                <item android:offset="0" android:color="#00000000" />
                <item android:offset="1" android:color="#40000000" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
